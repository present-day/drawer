{
  "name": "@present-day/drawer",
  "version": "1.1.1",
  "description": "A flexible drawer component with smooth animations and snap points",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "format": "biome check --write .",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "drawer",
    "modal",
    "animation",
    "framer-motion"
  ],
  "author": "Present Day",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/present-day/drawer.git"
  },
  "bugs": {
    "url": "https://github.com/present-day/drawer/issues"
  },
  "homepage": "https://github.com/present-day/drawer#readme",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "motion": ">=10.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3"
  }
}
