{
  "name": "@present-day/drawer",
  "version": "1.2.8",
  "description": "A flexible drawer component with smooth animations and snap points",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "packageManager": "bun@1.1.42",
  "scripts": {
    "playground": "vite --config playground/vite.config.mts",
    "playground:build": "vite build --config playground/vite.config.mts",
    "playground:preview": "vite preview --config playground/vite.config.mts",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "format": "biome check --write .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "react",
    "drawer",
    "modal",
    "animation",
    "framer-motion"
  ],
  "author": "Present Day",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/present-day/drawer.git"
  },
  "bugs": {
    "url": "https://github.com/present-day/drawer/issues"
  },
  "homepage": "https://github.com/present-day/drawer#readme",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "motion": ">=10.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwind-merge": "*"
  },
  "peerDependenciesMeta": {
    "tailwind-merge": {
      "optional": true
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "focus-trap": "^8.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-istanbul": "^2.1.9",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "motion": "^12.38.0",
    "postcss": "^8.4.49",
    "postcss-modules": "^6.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
